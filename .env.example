# Database
DATABASE_URL="postgresql://user:password@localhost:5432/marketing_engine?schema=public"

# Redis (for BullMQ job queue)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# SMTP Configuration (Your Postfix Server)
SMTP_HOST="mail.kiitconnect.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Email Rate Limits
SMTP_RATE_LIMIT="50"
SMTP_DAILY_LIMIT="100000"

# Default Sender
DEFAULT_FROM_NAME="Marketing Engine"
DEFAULT_FROM_EMAIL="noreply@kiitconnect.com"

# App URL (for tracking links)
BASE_URL="http://localhost:3000"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
